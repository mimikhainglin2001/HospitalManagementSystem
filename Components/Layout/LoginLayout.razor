@inherits LayoutComponentBase

<div class="login-page">
    <div class="login-container">
        <div class="illustration-panel">
            <div class="brand">
                <img src="assets/logo.svg" alt="HMS" />
            </div>
            <div class="illustration">
                <!-- Decorative illustration or image -->
                <img src="assets/sidebar-bg.svg" alt="illustration" />
            </div>
        </div>

        <div class="form-panel">
            <div class="form-card">
                <header class="form-header">
                    <h3>Sign In</h3>
                    <p class="muted">See your growth and get consulting support!</p>
                </header>

                <section class="form-body">
                    @Body
                </section>

                <footer class="form-footer">
                    <div class="small muted">Don't have an account yet? <a href="/Identity/Account/Register">Sign up here</a></div>
                </footer>
            </div>
        </div>
    </div>
</div>