@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization

<div class="sidebar-panel @(_collapsed ? "collapsed" : "")">
    <div class="sidebar-top">
        <div class="brand">
            <MudIcon Icon="@Icons.Material.Filled.LocalHospital" Class="brand-icon" />
            <span class="brand-label">HMS</span>
        </div>
        <MudIconButton Icon="@Icons.Material.Filled.Menu" OnClick="ToggleSidebar" Class="hamburger-btn" />
    </div>

    <div class="nav-scrollable">
        <MudNavMenu Class="sidebar-nav">

            <div class="section-label">Main</div>
            <MudNavLink Href="" Match="NavLinkMatch.All" Class="nav-link">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="nav-icon" />
                <span class="nav-text">Dashboard</span>
            </MudNavLink>

            <div class="section-label">Patient</div>
            <MudNavLink Href="/patients" Class="nav-link">
                <MudIcon Icon="@Icons.Material.Filled.People" Class="nav-icon" />
                <span class="nav-text">Patient</span>
            </MudNavLink>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="nav-icon" />
                <span class="nav-text">Billing</span>
            </div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="nav-icon" />
                <span class="nav-text">OPD-Out Patient</span>
            </div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Bed" Class="nav-icon" />
                <span class="nav-text">IPD-In Patient</span>
            </div>

            <div class="section-label">All Appointments</div>
            <MudNavGroup Title="Appointments" Icon="@Icons.Material.Filled.CalendarMonth" Class="nav-group">
                <MudNavLink Href="/appointments" Class="sub-link">
                    <span class="nav-text">Appointments</span>
                </MudNavLink>
                <MudNavLink Href="/appointmentslots" Class="sub-link">
                    <span class="nav-text">Appointment Slots</span>
                </MudNavLink>
            </MudNavGroup>

            <div class="section-label">Pharmacy</div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Medication" Class="nav-icon" />
                <span class="nav-text">Pharmacy</span>
            </div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.MedicalServices" Class="nav-icon" />
                <span class="nav-text">Radiology</span>
            </div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Bloodtype" Class="nav-icon" />
                <span class="nav-text">Blood Bank</span>
            </div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Emergency" Class="nav-icon" />
                <span class="nav-text">Ambulance</span>
            </div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Desk" Class="nav-icon" />
                <span class="nav-text">Front Office</span>
            </div>
            <div class="nav-link disabled-item">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="nav-icon" />
                <span class="nav-text">Duty Roster</span>
            </div>

            <div class="section-label">Human Resource</div>
            <MudNavGroup Title="Human Resource" Icon="@Icons.Material.Filled.Group" Class="nav-group">
                <MudNavLink Href="/departments" Class="sub-link">
                    <span class="nav-text">Departments</span>
                </MudNavLink>
                <MudNavLink Href="/countries" Class="sub-link">
                    <span class="nav-text">Countries</span>
                </MudNavLink>
                <MudNavLink Href="/users" Class="sub-link">
                    <span class="nav-text">System Users</span>
                </MudNavLink>
                <MudNavLink Href="/employees" Class="sub-link">
                    <span class="nav-text">Employees</span>
                </MudNavLink>
            </MudNavGroup>

            <div class="section-label">System Security</div>
            <MudNavGroup Title="System Security" Icon="@Icons.Material.Filled.Security" Class="nav-group">
                <MudNavLink Href="/systemcodes" Class="sub-link">
                    <span class="nav-text">System Codes</span>
                </MudNavLink>
                <MudNavLink Href="/systemcodedetails" Class="sub-link">
                    <span class="nav-text">System Code Details</span>
                </MudNavLink>
            </MudNavGroup>

        </MudNavMenu>
    </div>

    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <div class="user-row">
                    <MudAvatar Color="Color.Error" Size="Size.Small">@GetInitials(context.User.Identity?.Name)</MudAvatar>
                    <div class="user-info">
                        <div class="user-name">@context.User.Identity?.Name</div>
                        <div class="user-role">Administrator</div>
                    </div>
                </div>
                <MudNavLink Href="/Identity/Account/Logout" Class="logout-link">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" />
                    <span class="nav-text">Logout</span>
                </MudNavLink>
            </Authorized>
            <NotAuthorized>
                <MudNavLink Href="/Identity/Account/Login" Class="logout-link">
                    <MudIcon Icon="@Icons.Material.Filled.Login" />
                    <span class="nav-text">Login</span>
                </MudNavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    private bool _collapsed;

    private void ToggleSidebar()
    {
        _collapsed = !_collapsed;
    }

    private static string GetInitials(string? name)
    {
        if (!string.IsNullOrEmpty(name) && name.Length >= 2)
            return name[..2].ToUpper();
        return "U";
    }
}
