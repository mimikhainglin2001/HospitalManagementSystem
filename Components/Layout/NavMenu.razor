@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">HMIS_SYSTEM</a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column">

        <!-- Home -->
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill"></span>
                Home
            </NavLink>
        </div>

        <!-- System Codes -->
        <div class="nav-item">
            <NavLink class="nav-link" href="systemcodes">
                <span class="bi bi-gear-fill"></span>
                System Codes
            </NavLink>
        </div>

        <!-- Code Details -->
        <div class="nav-item">
            <NavLink class="nav-link" href="systemcodedetails">
                <span class="bi bi-card-list"></span>
                Code Details
            </NavLink>
        </div>

        <!-- Departments -->
        <div class="nav-item">
            <NavLink class="nav-link" href="departments">
                <span class="bi bi-building"></span>
                Departments
            </NavLink>
        </div>

        <!-- Countries -->
        <div class="nav-item">
            <NavLink class="nav-link" href="countries">
                <span class="bi bi-globe2"></span>
                Countries
            </NavLink>
        </div>

        <!-- Auth Section -->
        <AuthorizeView>
            <Authorized>
                <div class="nav-item">
                    <div class="nav-link text-white-50">
                        <span class="bi bi-person-circle"></span>
                        @context.User.Identity?.Name
                    </div>
                </div>
                <div class="nav-item">
                    <a class="nav-link" href="/Identity/Account/Logout">
                        <span class="bi bi-box-arrow-right"></span>
                        Logout
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="/Identity/Account/Login">
                        <span class="bi bi-box-arrow-in-right"></span>
                        Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>