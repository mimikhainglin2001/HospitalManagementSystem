@page "/addemployee"
@page "/addemployee/{Id:int}"
@rendermode InteractiveServer

@using HospitalManagementSystem.Data
@using HospitalManagementSystem.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> userManager
@inject NavigationManager navigation
@inject ISnackbar Snackbar

@attribute [Authorize]

<div class="mx-2">
    <MudPaper Elevation="15" Class="p-4">

        <EditForm Model="employee" OnValidSubmit="CreateOrUpdateEmployee" FormName="addemployee">

            <DataAnnotationsValidator />

            <h3>@(Id.HasValue ? "Update Employee" : "Add New Employee")</h3>

            <MudGrid>

                <MudItem xs="12" sm="6" md="4">
                    <label>Employee No</label>
                    <MudTextField @bind-Value="employee.EmployeeNo"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>First Name</label>
                    <MudTextField @bind-Value="employee.FirstName"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Middle Name</label>
                    <MudTextField @bind-Value="employee.MiddleName"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Last Name</label>
                    <MudTextField @bind-Value="employee.LastName"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Email</label>
                    <MudTextField @bind-Value="employee.EmailAddress"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Phone</label>
                    <MudTextField @bind-Value="employee.PhoneNumber"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Date of Birth</label>
                    <MudTextField @bind-Value="dateOfBirth"
                                  InputType="InputType.Date"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Date of Joining</label>
                    <MudTextField @bind-Value="dateOfJoining"
                                  InputType="InputType.Date"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>ID Number <span class="text-danger">*</span></label>
                    <MudTextField @bind-Value="employee.IdNumber"
                                  For="@(() => employee.IdNumber)"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                    <ValidationMessage For="@(() => employee.IdNumber)" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Department</label>
                    <MudSelect @bind-Value="employee.DepartmentId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select department">
                        @foreach (var d in Departments)
                        {
                            <MudSelectItem Value="@((int?)d.Id)">@d.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Role</label>
                    <MudSelect @bind-Value="employee.RoleId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select role">
                        @foreach (var r in Roles)
                        {
                            <MudSelectItem Value="@((int?)r.Id)">@r.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Designation</label>
                    <MudSelect @bind-Value="employee.DesignationId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select designation">
                        @foreach (var d in Designations)
                        {
                            <MudSelectItem Value="@((int?)d.Id)">@d.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Specialist</label>
                    <MudSelect @bind-Value="employee.SpecialistId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select specialist">
                        @foreach (var s in Specialities)
                        {
                            <MudSelectItem Value="@((int?)s.Id)">@s.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Gender</label>
                    <MudSelect @bind-Value="employee.GenderId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select gender">
                        @foreach (var g in Genders)
                        {
                            <MudSelectItem Value="@((int?)g.Id)">@g.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Blood Group</label>
                    <MudSelect @bind-Value="employee.BloodGroupId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select blood group">
                        @foreach (var b in BloodGroups)
                        {
                            <MudSelectItem Value="@((int?)b.Id)">@b.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Marital Status</label>
                    <MudSelect @bind-Value="employee.MaritalStatusId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select marital status">
                        @foreach (var m in MAS)
                        {
                            <MudSelectItem Value="@((int?)m.Id)">@m.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Father Name</label>
                    <MudTextField @bind-Value="employee.FatherName"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <label>Mother Name</label>
                    <MudTextField @bind-Value="employee.MotherName"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                </MudItem>

            </MudGrid>

            <div class="mt-4">
                <MudStack Row Justify="Justify.SpaceBetween">

                    <MudButton Href="/employees"
                               Variant="Variant.Filled"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.ArrowBack">
                        Back To List
                    </MudButton>

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save">
                        @(Id.HasValue ? "Update Employee" : "Save Employee")
                    </MudButton>

                </MudStack>
            </div>

        </EditForm>

    </MudPaper>
</div>

@code {

    [Parameter] public int? Id { get; set; }

    private Employee employee = new();
    private DateTime? dateOfBirth;
    private DateTime? dateOfJoining;
    private string? UserId;

    private List<Department> Departments = new();
    private List<SystemCodeDetail> Roles = new();
    private List<SystemCodeDetail> Designations = new();
    private List<SystemCodeDetail> Specialities = new();
    private List<SystemCodeDetail> Genders = new();
    private List<SystemCodeDetail> BloodGroups = new();
    private List<SystemCodeDetail> MAS = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var currentUser = await userManager.GetUserAsync(user);
            UserId = currentUser?.Id;
        }

        await LoadLookups();

        if (Id.HasValue)
        {
            employee = await employeeService.GetEmployeeByIdAsync(Id.Value) ?? new();
            dateOfBirth = employee.DateOfBirth;
            dateOfJoining = employee.DateOfJoining;
        }
    }

    private async Task LoadLookups()
    {
        try
        {
            Departments = await departmentService.GetDepartmentsAsync() ?? new();

            var all = await systemCodeDetailsService.GetSystemCodeDetailsAsync() ?? new();

            Roles = all.Where(x => x.SystemCode?.Code == "Roles").ToList();
            Designations = all.Where(x => x.SystemCode?.Code == "Designations").ToList();
            Specialities = all.Where(x => x.SystemCode?.Code == "Specialities").ToList();
            Genders = all.Where(x => x.SystemCode?.Code == "Gender").ToList();
            BloodGroups = all.Where(x => x.SystemCode?.Code == "BloodGroups").ToList();
            MAS = all.Where(x => x.SystemCode?.Code == "MAS").ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.InnerException?.Message ?? ex.Message, Severity.Error);
        }
    }

    private async Task CreateOrUpdateEmployee()
    {
        try
        {
            if (dateOfBirth.HasValue)
                employee.DateOfBirth = dateOfBirth.Value;
            if (dateOfJoining.HasValue)
                employee.DateOfJoining = dateOfJoining.Value;

            if (Id.HasValue)
            {
                employee.ModifiedOn = DateTime.UtcNow;
                employee.ModifiedById = UserId;
                await employeeService.UpdateEmployeeAsync(employee);
                Snackbar.Add("Employee Updated", Severity.Success);
            }
            else
            {
                employee.CreatedOn = DateTime.UtcNow;
                employee.CreatedById = UserId;

                await employeeService.AddEmployeeAsync(employee);
                Snackbar.Add("Employee Created", Severity.Success);
            }

            navigation.NavigateTo("/employees");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.InnerException?.Message ?? ex.Message, Severity.Error);
        }
    }
}
