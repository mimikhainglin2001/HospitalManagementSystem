@page "/addsystemcode"
@using HospitalManagementSystem.Data
@using HospitalManagementSystem.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> userManager
@inject NavigationManager navigation
@attribute [Authorize]
<div class = "mx-2">
<MudPaper Elevation="15" Class="p-4">
<div class="row">
    <EditForm Model="systemCode"
              OnValidSubmit="CreateNewSystemCode"
              FormName="addsystemcode">
        <DataAnnotationsValidator />
        <ValidationSummary /> 

         <div class="col-md-12">
            <h3>Add New System Code </h3>
        </div>

        <div class="col-md-12">
            <div class="row">

                <!-- Code -->
                <div class="form-group col-md-6">
                    <label>Code</label>
                    <InputText class="form-control"
                               @bind-Value="systemCode.Code"
                               placeholder="Enter system code" />
                    <ValidationMessage For="@(() => systemCode.Code)" />
                </div>

                <!-- Description -->
                <div class="form-group col-md-6">
                    <label>Name</label>
                    <InputText class="form-control"
                               @bind-Value="systemCode.Description"
                               placeholder="Enter system code name" />
                    <ValidationMessage For="@(() => systemCode.Description)" />
                </div>

                <!-- Order No -->
                <div class="form-group col-md-6">
                    <label>Order No</label>
                    <InputNumber class="form-control"
                                 @bind-Value="systemCode.OrderNo" />
                    <ValidationMessage For="@(() => systemCode.OrderNo)" />
                </div>

            </div>

            <div class="form-group mt-4">
                <MudItem xs = "12" mt-4>
                    <MudStack Row Justify="Justify.SpaceBetween">
                    <MudButton Href="/systemcodes"
                               Variant="Variant.Filled"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.ArrowBack">
                        Back To List
                    </MudButton>
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Class="float-end">
                    Save System Code
                </MudButton>
                    </MudStack>
                </MudItem>
            </div>

        </div>
    </EditForm>
</div>
    </MudPaper>
    </div>


@code {
    [SupplyParameterFromForm]
    public SystemCode? systemCode { get; set; }

    public string? UserId;

    protected override async Task OnInitializedAsync()
    {
        systemCode ??= new SystemCode();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var currentUser = await userManager.GetUserAsync(user);
            UserId = currentUser?.Id;
        }
    }

    protected async Task CreateNewSystemCode()
    {
        systemCode.CreatedOn = DateTime.UtcNow;
        systemCode.CreatedById = UserId;
        systemCode.ModifiedOn = DateTime.UtcNow;
        systemCode.ModifiedById = UserId;

        await systemCodeService.AddSystemCodeAsync(systemCode);

        navigation.NavigateTo("/systemcodes");
    }

    public void BackToList()
    {
        navigation.NavigateTo("/systemcodes");
    }
}