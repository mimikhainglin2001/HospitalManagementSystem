@page "/addsystemcodedetails"
@rendermode InteractiveServer
@using HospitalManagementSystem.Data
@using HospitalManagementSystem.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> userManager
@inject NavigationManager navigation
@inject ISnackbar Snackbar

@attribute [Authorize]

<div class="mx-2">
    <MudPaper Elevation="15" Class="p-4">

        <EditForm Model="systemCodeDetail"
                  OnValidSubmit="CreateNewSystemCode"
                  FormName="addsystemcodedetails">

            <DataAnnotationsValidator />

            <h3>Add New System Code Details</h3>

            <MudGrid>

                <MudItem xs="12" sm="6" md="6">
                    <label>Code <span class="text-danger">*</span></label>
                    <MudTextField @bind-Value="systemCodeDetail.Code"
                                  Placeholder="Enter system code"
                                  For="@(() => systemCodeDetail.Code)"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                    <ValidationMessage For="@(() => systemCodeDetail.Code)" />
                </MudItem>

                <MudItem xs="12" sm="6" md="6">
                    <label>Name <span class="text-danger">*</span></label>
                    <MudTextField @bind-Value="systemCodeDetail.Description"
                                  Placeholder="Enter system code name"
                                  For="@(() => systemCodeDetail.Description)"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                    <ValidationMessage For="@(() => systemCodeDetail.Description)" />
                </MudItem>

                <MudItem xs="12" sm="6" md="6">
                    <label>System Code <span class="text-danger">*</span></label>
                    <MudSelect @bind-Value="selectedSystemCodeId"
                               Variant="Variant.Outlined"
                               FullWidth="@true"
                               T="int?"
                               Placeholder="Select system code">
                        @if (SystemCodes != null)
                        {
                            foreach (var item in SystemCodes)
                            {
                                <MudSelectItem Value="@((int?)item.Id)">@item.Description</MudSelectItem>
                            }
                        }
                    </MudSelect>
                    <ValidationMessage For="@(() => systemCodeDetail.SystemCodeId)" />
                </MudItem>

                <MudItem xs="12" sm="6" md="6">
                    <label>Order No</label>
                    <MudTextField @bind-Value="systemCodeDetail.OrderNo"
                                  InputType="InputType.Number"
                                  For="@(() => systemCodeDetail.OrderNo)"
                                  Variant="Variant.Outlined"
                                  FullWidth="@true" />
                    <ValidationMessage For="@(() => systemCodeDetail.OrderNo)" />
                </MudItem>

            </MudGrid>

            <div class="mt-4">
                <MudStack Row Justify="Justify.SpaceBetween">

                    <MudButton Href="/systemcodedetails"
                               Variant="Variant.Filled"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.ArrowBack">
                        Back To List
                    </MudButton>

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save">
                        Save System Code Details
                    </MudButton>

                </MudStack>
            </div>

        </EditForm>

    </MudPaper>
</div>

@code {
    private SystemCodeDetail systemCodeDetail = new();
    private int? selectedSystemCodeId;
    public List<SystemCode> SystemCodes = new();
    public string? UserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var currentUser = await userManager.GetUserAsync(user);
            UserId = currentUser?.Id;
        }

        SystemCodes = await systemCodeService.GetSystemCodesAsync() ?? new();
    }

    protected async Task CreateNewSystemCode()
    {
        if (selectedSystemCodeId.HasValue)
            systemCodeDetail.SystemCodeId = selectedSystemCodeId.Value;

        systemCodeDetail.CreatedOn = DateTime.UtcNow;
        systemCodeDetail.CreatedById = UserId;
        systemCodeDetail.ModifiedOn = DateTime.UtcNow;
        systemCodeDetail.ModifiedById = UserId;

        await systemCodeDetailsService.AddSystemCodeDetailAsync(systemCodeDetail);

        navigation.NavigateTo("/systemcodedetails?created=true");
    }
}
