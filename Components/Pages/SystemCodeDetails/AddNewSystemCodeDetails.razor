@page "/addsystemcodedetails"
@rendermode InteractiveServer
@using HospitalManagementSystem.Data
@using HospitalManagementSystem.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> userManager
@inject NavigationManager navigation
@inject ISnackbar Snackbar

@attribute [Authorize]
<div class = "mx-2">
<MudPaper Elevation="15" Class="p-4">
<div class="row">
    <EditForm Model="systemCodeDetail"
              OnValidSubmit="CreateNewSystemCode"
              FormName="addsystemcodedetails">

        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="col-md-12">
            <h3>Add New System Code Details</h3>
        </div>

        <div class="col-md-12">
            <div class="row">

                <!-- Code -->
                <div class="form-group col-md-6">
                    <label>Code</label>
                    <InputText class="form-control"
                               @bind-Value="systemCodeDetail.Code"
                               placeholder="Enter system code" />
                    <ValidationMessage For="@(() => systemCodeDetail.Code)" />
                </div>

                <!-- Description -->
                <div class="form-group col-md-6">
                    <label>Name</label>
                    <InputText class="form-control"
                               @bind-Value="systemCodeDetail.Description"
                               placeholder="Enter system code name" />
                    <ValidationMessage For="@(() => systemCodeDetail.Description)" />
                </div>

                <!-- System Code -->
                <div class="form-group col-md-6">
                    <label>System Code</label>

                    <InputSelect class="form-control"
                                 @bind-Value="systemCodeDetail.SystemCodeId">
                        <option value="">Select System Code</option>

                        @if (SystemCodes != null)
                        {
                            foreach (var item in SystemCodes)
                            {
                                <option value="@item.Id">@item.Description</option>
                            }
                        }
                    </InputSelect>

                    <ValidationMessage For="@(() => systemCodeDetail.SystemCodeId)" />
                </div>

                <!-- Order No -->
                <div class="form-group col-md-6">
                    <label>Order No</label>
                    <InputNumber class="form-control"
                                 @bind-Value="systemCodeDetail.OrderNo" />
                    <ValidationMessage For="@(() => systemCodeDetail.OrderNo)" />
                </div>
 
            </div>

            <div class="form-group mt-4">
                <MudItem xs = "12" mt-4>
                    <MudStack Row Justify="Justify.SpaceBetween">
                    <MudButton Href="/systemcodedetails"
                               Variant="Variant.Filled"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.ArrowBack">
                        Back To List
                    </MudButton>
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Class="float-end">
                    Save System Code Details
                </MudButton>
                    </MudStack>
                </MudItem>
            </div>

        </div>
    </EditForm>
</div>
    </MudPaper>
    </div>

@code {
    [SupplyParameterFromForm]
    public SystemCodeDetail? systemCodeDetail { get; set; }

    public List<SystemCode> SystemCodes = new();
    public string? UserId;

    protected override async Task OnInitializedAsync()
    {
        systemCodeDetail ??= new SystemCodeDetail();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var currentUser = await userManager.GetUserAsync(user);
            UserId = currentUser?.Id;
        }

        SystemCodes = await systemCodeService.GetSystemCodesAsync() ?? new();
    }

    protected async Task CreateNewSystemCode()
    {
        systemCodeDetail.CreatedOn = DateTime.UtcNow;
        systemCodeDetail.CreatedById = UserId;
        systemCodeDetail.ModifiedOn = DateTime.UtcNow;
        systemCodeDetail.ModifiedById = UserId;

        await systemCodeDetailsService.AddSystemCodeDetailAsync(systemCodeDetail);

        navigation.NavigateTo("/systemcodedetails?created=true");
    }

    public void BackToList()
    {
        navigation.NavigateTo("/systemcodedetails");
    }
}