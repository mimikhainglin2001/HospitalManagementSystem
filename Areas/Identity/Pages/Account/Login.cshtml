@page
@model LoginModel

@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Log in";
}
<div>
    <section>
        <form id="account" method="post">
            <div class="form-header">
                <h1>Welcome back</h1>
                <p>Sign in to manage hospital access and patient workflows securely.</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-body">
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="d-flex remember-row">
                    <label class="form-label mb-0 d-flex align-items-center">
                        <input class="form-check-input me-2" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                    <a id="forgot-password" asp-page="./ForgotPassword">Forgot Password?</a>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="btn btn-primary">Sign In</button>
                </div>
            </div>

            <div class="form-footer-links">
                <p class="mb-1">Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create one now</a></p>
                <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a></p>
            </div>
        </form>
    </section>

    <section class="mt-4">
        <div class="section-title">Continue with another service</div>
        <p class="section-muted">Use an external account to sign in quickly.</p>
        @{
            if ((Model.ExternalLogins?.Count ?? 0) == 0)
            {
                <div>
                    <p>
                        There are no external authentication services configured. See this <a href="https://go.microsoft.com/fwlink/?LinkID=532715">article
                        about setting up this ASP.NET application to support logging in via external services</a>.
                    </p>
                </div>
            }
            else
            {
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                    <div class="social-row">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="social-btn" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                        }
                    </div>
                </form>
            }
        }
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
